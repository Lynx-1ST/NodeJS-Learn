    // Variable - Biến
    - var name = "Đào Quang Lộc"
    - var phone = "0389770636"
    - var age = 20

    div.info-user
      p= name
      p= phone
      p= age

    // Nối chuỗi
    p Xin chào #{name}
    p Số điện thoại: #{phone}
    p Tuổi: #{age}

    - var htmlLink = "<a href='https://daca.vn'>Daca.vn</a>"
    div.link
      p !{htmlLink}

    // Conditionals - Điều kiện
    -
      var infoUser = {
        name: "Đào Quang Lộc",
        phone: "0123456789",
        age: 19
      }

    p= infoUser.name

    if infoUser.phone
      p Số điện thoại: #{infoUser.phone}
    else
      p Số điện thoại: Chưa có

    // or
    p Số điện thoại: #{infoUser.phone ? infoUser.phone : "Chưa có"}

// status-account: "initial", "active", "inactive"
- var statusAccount = "inactive";

case statusAccount
  when "initial"
    p Chờ duyệt
  when "active"
    p Đang hoạt động
  when "inactive"
    p Đang bị khoá
  default 
    p Không có

  // Iteration - Vòng lặp
-
  var listUser = [
    "Le Van A",
    "Nguyen Thi B",
    "Do Van C"
  ]

  // List user
ul 
  each item, index in listUser
    li #{index + 1}. #{item}

ul
  - for (let i = 0; i < 10; i++)
    li #{i}

  // Operation - Toán tử
- var numA = 10;
- var numB = 20;
if numA < numB 
  p Số A nhỏ hơn số B
else 
  p Số A nhỏ hơn hoặc bằng B
